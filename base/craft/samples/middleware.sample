<?php

	declare(strict_types=1);

	namespace <NAMESPACE>;

	use Base\Middleware;

	/**
	 * Пользовательское программное обеспечение
	 */
	class <CLASS> extends Middleware {

		/**
		 * Before
		 * @return bool
		 */
